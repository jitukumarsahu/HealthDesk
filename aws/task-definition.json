{
  "family": "healthdesk-production-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "1024",
  "memory": "2048",
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "408945636435.dkr.ecr.ap-south-1.amazonaws.com/healthdesk-backend:latest",
      "cpu": 512,
      "memory": 1024,
      "portMappings": [
        {
          "containerPort": 5000,
          "hostPort": 5000,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "PORT",
          "value": "5000"
        },
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "CORS_ORIGIN",
          "value": "http://localhost:3000"
        }
      ],
      "secrets": [
        {
          "name": "MONGO_URI",
          "valueFrom": "arn:aws:ssm:ap-south-1:408945636435:parameter/healthdesk/prod/MONGO_URI"
        },
        {
          "name": "JWT_ACCESS_SECRET",
          "valueFrom": "arn:aws:ssm:ap-south-1:408945636435:parameter/healthdesk/prod/JWT_ACCESS_SECRET"
        },
        {
          "name": "JWT_REFRESH_SECRET",
          "valueFrom": "arn:aws:ssm:ap-south-1:408945636435:parameter/healthdesk/prod/JWT_REFRESH_SECRET"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/healthdesk-production",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "backend"
        }
      }
    },
    {
      "name": "frontend",
      "image": "408945636435.dkr.ecr.ap-south-1.amazonaws.com/healthdesk-frontend:latest",
      "cpu": 512,
      "memory": 1024,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "PORT",
          "value": "3000"
        },
        {
          "name": "NEXT_PUBLIC_API_URL",
          "value": "http://localhost:5000/api"
        },
        {
          "name": "NEXT_PUBLIC_SOCKET_URL",
          "value": "http://localhost:5000"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/healthdesk-production",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "frontend"
        }
      }
    }
  ]
}
